{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the popup and settings windows",
  "windows": ["popup", "settings"],
  "permissions": [
    "core:default",
    "opener:default",
    "notification:default",
    "store:default",
    "positioner:default",
    "autostart:default",
    "global-shortcut:default"
  ]
}
